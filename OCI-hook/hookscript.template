#!/usr/bin/bash

echo "WASP SWAP hook"

set -x

CG_PATH=$(jq -er '.linux.cgroupsPath' < config.json)
PID=$(jq -er '.pid' < config.json)

if [ -n "$PID" ] && [ -d "/proc/$PID" ]; then
  if [[ "$CG_PATH" =~ .*"burst".* ]]; then
    CONTAINERID=$(jq -er '.linux.cgroupsPath | split(":")[2]' < config.json)
    {{ .RuntimeCmd }}
  fi
fi
